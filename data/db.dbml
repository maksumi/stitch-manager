Table role {
  id serial [pk]
  name varchar [unique]
}

Table user {
  id serial [pk]
  full_name varchar
  phone varchar
  email varchar [unique]
  password_hash varchar

  role_id int [ref: > role.id]

  created_at timestamp
  updated_at timestamp
}

Table client {
  id serial [pk]
  name varchar
  address varchar
  rfc varchar
  phone varchar
  email varchar

  created_at timestamp
  updated_at timestamp
}

Table logo {
  id serial [pk]
  client_id int [ref: > client.id]
  name varchar
  stitch_count int

  created_at timestamp
  updated_at timestamp
}

Table order {
  id serial [pk]
  folio int [unique]
  client_id int [ref: > client.id]

  status order_status

  date_authorized date
  date_delivery date
  date_received date

  created_at timestamp
  updated_at timestamp
}

Table line_item {
  id serial [pk]
  order_id int [ref: > order.id]
  logo_id int [ref: > logo.id]

  garment_type varchar
  garment_provider garment_provider
  garment_color varchar

  quantity int

  logo_status logo_status

  logo_position varchar
  embroidery_color varchar
  embroidery_type varchar

  notes text

  created_at timestamp
  updated_at timestamp
}

Table machine {
  id serial [pk]
  name varchar [unique]
}

Table production_record {
  id serial [pk]

  line_item_id int [ref: > line_item.id]
  operator_id int [ref: > user.id]
  machine_id int [ref: > machine.id]

  record_date date

  pieces_done int

  waste_type waste_type
  waste_quantity int

  notes text

  created_at timestamp
  updated_at timestamp
}